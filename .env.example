# =============================================================================
# Backend Team Local SonarQube — configuration
# =============================================================================
# Edit this file to customise the stack. All values have sensible defaults;
# change only what you need.
# =============================================================================

# -----------------------------------------------------------------------------
# SonarQube
# -----------------------------------------------------------------------------

# Host port exposed to your machine (internal container port is always 9000).
SONAR_PORT=9000

# Admin credentials used by the setup and analysis scripts.
SONAR_USER=admin
SONAR_PASSWORD=admin

# -----------------------------------------------------------------------------
# Quality Gate — "Backend Team QG"
# Ratings use numeric values: 1=A  2=B  3=C  4=D  5=E
# -----------------------------------------------------------------------------

# Name of the Quality Gate created in SonarQube.
QG_NAME=Backend Team QG

# Maximum number of total issues allowed.
QG_MAX_VIOLATIONS=10

# Minimum percentage of security hotspots that must be reviewed.
QG_MIN_HOTSPOTS_REVIEWED=100

# Minimum line coverage percentage.
QG_MIN_COVERAGE=80

# Maximum duplicated lines percentage.
QG_MAX_DUPLICATIONS=15

# Maintainability (sqale) rating threshold  — fail if worse than this value.
QG_MAX_MAINTAINABILITY=1

# Reliability rating threshold  — fail if worse than this value.
QG_MAX_RELIABILITY=3

# Security rating threshold  — fail if worse than this value.
QG_MAX_SECURITY=3
